{
  "manifest_version": 3,
  "name": "JobsIn 助手",
  "version": "1.2.0",
  "description": "JobsIn 多平台岗位采集助手 — 智能采集与自动投递",
  "permissions": [
    "tabs",
    "activeTab",
    "storage"
  ],
  "host_permissions": [
    "https://www.zhipin.com/*",
    "https://login.zhipin.com/*",
    "http://localhost:27788/*",
    "http://127.0.0.1:27788/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://www.zhipin.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "JobsIn 助手"
  }
}
